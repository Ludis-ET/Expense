{
  "name": "santim",
  "version": "0.1.0",
  "private": true,
  "description": "Santim - personal income & expense tracker. Express/Prisma backend + Next.js frontend.",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:backend": "pnpm --filter @santim/backend dev",
    "dev:frontend": "pnpm --filter @santim/frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @santim/backend db:migrate",
    "db:seed": "pnpm --filter @santim/backend db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
