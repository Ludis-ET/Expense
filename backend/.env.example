# --- Server ---
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database ---
# Connection string for any PostgreSQL 16 instance. For a free hosted option,
# create a project at https://neon.tech and paste its connection string here
# (Neon dashboard -> your project -> "Connection string", pooled connection).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth ---
# Generate a strong secret, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- AI ---
# Optional: dedicated key for encrypting users' stored AI provider API keys at rest.
# Falls back to JWT_SECRET if unset. Set a distinct value in production.
# AI_ENCRYPTION_KEY=another-long-random-string
# Base URL of the frontend, used to build shareable invite links.
APP_URL=http://localhost:3000

# --- Logging ---
LOG_LEVEL=debug
