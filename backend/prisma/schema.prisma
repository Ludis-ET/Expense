// Santim data model — personal finance.
// Privacy model: every row is owned by exactly one User via userId (directly
// or via its parent). Services always filter by the authenticated user's id.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TxKind {
  INCOME
  EXPENSE
  TRANSFER
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum AccountType {
  CASH
  BANK
  MOBILE_MONEY
  CARD
  OTHER
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum HouseholdRole {
  OWNER
  PARTNER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// Personal IOUs: money lent/borrowed, and one-off income you're still waiting on.
enum LedgerKind {
  LENT         // you gave money — they owe you
  BORROWED     // you borrowed — you owe them
  EXPECTED_IN  // income coming (not on a recurring schedule)
}

enum LedgerStatus {
  OPEN
  SETTLED
  CANCELLED
}

model User {
  id             String @id @default(cuid())
  email          String @unique
  passwordHash   String
  name           String
  locale         String @default("en")
  calendar       String @default("gregorian") // "gregorian" | "ethiopian" — display preference
  currency       String @default("ETB") // default display/entry currency
  firstDayOfWeek Int    @default(1) // 1 = Monday, 0 = Sunday

  accounts          Account[]
  categories        Category[]
  transactions      Transaction[]
  recurringRules    RecurringRule[]
  budgets           Budget[]
  goals             SavingsGoal[]
  notifications     Notification[]
  aiSetting         AiSetting?
  householdMembers  HouseholdMember[]
  sentInvites       HouseholdInvite[] @relation("InviteSender")
  ledgerEntries     LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Household {
  id      String @id @default(cuid())
  name    String @default("Our Household")

  members  HouseholdMember[]
  invites  HouseholdInvite[]
  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("households")
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        HouseholdRole @default(PARTNER)
  joinedAt    DateTime      @default(now())

  @@unique([householdId, userId])
  @@index([userId])
  @@map("household_members")
}

model HouseholdInvite {
  id          String       @id @default(cuid())
  householdId String
  household   Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  email       String
  token       String       @unique @default(cuid())
  invitedById String
  invitedBy   User         @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  @@index([email, status])
  @@map("household_invites")
}

model Account {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId    String?
  household      Household?  @relation(fields: [householdId], references: [id], onDelete: SetNull)
  isShared       Boolean     @default(false) // visible to all household members
  name           String // "Cash", "CBE", "Telebirr"
  type           AccountType @default(CASH)
  currency       String      @default("ETB")
  openingBalance Decimal     @default(0) @db.Decimal(14, 2)
  icon           String? // lucide icon name
  color          String? // hex
  isDefault      Boolean     @default(false)
  archived       Boolean     @default(false)

  transactions   Transaction[]   @relation("TxAccount")
  transfersIn    Transaction[]   @relation("TxTransferAccount")
  recurringRules RecurringRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([householdId])
  @@map("accounts")
}

model Category {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  kind      CategoryKind
  icon      String       @default("circle") // lucide icon name
  color     String       @default("#64748b")
  isDefault Boolean      @default(false) // seeded at registration
  archived  Boolean      @default(false)

  transactions   Transaction[]
  recurringRules RecurringRule[]
  budget         Budget?
  ledgerEntries  LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name, kind])
  @@index([userId])
  @@map("categories")
}

model Transaction {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind     TxKind
  amount   Decimal  @db.Decimal(14, 2) // always positive; kind carries the sign
  currency String   @default("ETB")
  date     DateTime

  accountId         String
  account           Account   @relation("TxAccount", fields: [accountId], references: [id], onDelete: Cascade)
  transferAccountId String? // destination account, TRANSFER only
  transferAccount   Account?  @relation("TxTransferAccount", fields: [transferAccountId], references: [id], onDelete: SetNull)
  categoryId        String? // null for transfers
  category          Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  note            String?
  payee           String? // merchant / person
  tags            String[]       @default([])
  receiptUrl      String?
  recurringRuleId String?
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([userId, kind])
  @@index([accountId])
  @@map("transactions")
}

model RecurringRule {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String // "Salary", "Rent", "Netflix"
  kind       TxKind // INCOME or EXPENSE (no recurring transfers, v1)
  amount     Decimal   @db.Decimal(14, 2)
  currency   String    @default("ETB")
  accountId  String
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  payee      String?
  note       String?

  frequency  Frequency
  interval   Int       @default(1) // every N periods
  dayOfMonth Int? // MONTHLY: clamp 29–31 to month end
  nextRun    DateTime
  endDate    DateTime?
  autoPost   Boolean   @default(true) // false = remind-only notification
  active     Boolean   @default(true)
  lastRunAt  DateTime?

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, active, nextRun])
  @@map("recurring_rules")
}

model Budget {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String   @unique // one ongoing monthly budget per category
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(14, 2) // monthly limit
  alertThreshold Int      @default(80) // % — notify when crossed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("budgets")
}

model SavingsGoal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  icon         String?
  color        String?
  targetAmount Decimal   @db.Decimal(14, 2)
  deadline     DateTime?
  note         String?
  achievedAt   DateTime?

  contributions GoalContribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("savings_goals")
}

model GoalContribution {
  id     String      @id @default(cuid())
  goalId String
  goal   SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount Decimal     @db.Decimal(14, 2)
  date   DateTime    @default(now())
  note   String?

  createdAt DateTime @default(now())

  @@index([goalId])
  @@map("goal_contributions")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  link      String?
  readFlag  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, readFlag])
  @@map("notifications")
}

// Per-user AI provider configuration. `providers` is an ordered JSON array
// (priority order) of { id, model, enabled, keyEnc }. API keys are encrypted
// at rest (AES-256-GCM) and never returned to the client.
model AiSetting {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providers Json     @default("[]")
  updatedAt DateTime @updatedAt

  @@map("ai_settings")
}

model LedgerEntry {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         LedgerKind
  counterparty String // person or org name
  title        String? // optional label, e.g. "Freelance invoice #12"
  totalAmount  Decimal       @db.Decimal(14, 2)
  currency     String        @default("ETB")
  dueDate      DateTime?
  note         String?
  status       LedgerStatus  @default(OPEN)
  settledAt    DateTime?
  categoryId   String? // income category hint for EXPECTED_IN / repayments
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  payments LedgerPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, kind])
  @@map("ledger_entries")
}

model LedgerPayment {
  id            String      @id @default(cuid())
  ledgerEntryId String
  ledgerEntry   LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(14, 2)
  date          DateTime    @default(now())
  note          String?
  transactionId String? // linked account transaction, if recorded

  createdAt DateTime @default(now())

  @@index([ledgerEntryId])
  @@map("ledger_payments")
}
